/porymap_src/
/porymap/
/qt_sdk/

# ── Python runtime ──
__pycache__/
*.pyc
*.pyo
.venv/
venv/
cleanenv/
_venv_off/

# ── IDE / editor ──
.idea/
.vscode/
.cursor/
.claude/
*.swp
*~
*.autosave
Thumbs.db
.DS_Store

# ── Logs ──
crashlogs/
*.log

# ── Cache (working files for open projects) ──
cache/

